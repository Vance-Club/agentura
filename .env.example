# Required: GitHub token for cloning private repos
GITHUB_TOKEN=ghp_...

# Repo URLs cloned at executor startup
SKILLS_REPO=https://github.com/your-org/agentura-skills.git
VANCE_ANDROID_REPO=https://github.com/your-org/vance-android.git
VANCE_IOS_REPO=https://github.com/your-org/vance-ios.git

# Required: at least one LLM API key
# ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=your-openrouter-key-here

# Optional: PostgreSQL password override
# DB_PASSWORD=agentura_dev

# Optional: Slack integration
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_TOKEN=xapp-...
